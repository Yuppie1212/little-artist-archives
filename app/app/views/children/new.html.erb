<div class="form-container">
  <h1 class="page-title">👶 こどもを登録する</h1>

  <%= form_with model: @child, class: "form-card", multipart: true do |f| %>
    <%= render "form", f: f, child: @child %>
    <div class="form-actions">
      <%= f.submit "登録する", class: "btn btn-accent btn-lg" %>
      <%= link_to "もどる", children_path, class: "btn btn-outline btn-lg" %>
    </div>
  <% end %>
</div>
