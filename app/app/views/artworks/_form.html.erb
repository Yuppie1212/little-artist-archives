<% if artwork.errors.any? %>
  <div class="error-box">
    <p class="error-box-title">⚠️ 入力内容をご確認ください</p>
    <ul class="error-box-list">
      <% artwork.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="form-group">
  <%= f.label :title, "タイトル", class: "form-label" %>
  <%= f.text_field :title, class: "form-input", placeholder: "例：おひさまとにじ" %>
</div>

<div class="form-group">
  <%= f.label :drawn_at, "描いた日", class: "form-label" %>
  <%= f.date_field :drawn_at, class: "form-input" %>
</div>

<div class="form-group">
  <%= f.label :what_drawn, "何を描いたか", class: "form-label" %>
  <%= f.text_field :what_drawn, class: "form-input", placeholder: "例：おひさまとにじといえ" %>
</div>

<div class="form-group">
  <%= f.label :why_drawn, "なぜ描いたか", class: "form-label" %>
  <%= f.text_area :why_drawn, class: "form-input form-textarea", placeholder: "例：お空がきれいだったから", rows: 3 %>
</div>

<div class="form-group">
  <%= f.label :child_comment, "こどものコメント", class: "form-label" %>
  <%= f.text_area :child_comment, class: "form-input form-textarea", placeholder: "こどもが話してくれたこと", rows: 3 %>
</div>

<div class="form-group">
  <%= f.label :parent_memo, "親のメモ", class: "form-label" %>
  <%= f.text_area :parent_memo, class: "form-input form-textarea", placeholder: "親として気づいたことや感じたこと", rows: 3 %>
</div>

<div class="form-group">
  <label class="form-label">🖼️ 作品の写真</label>
  <% existing = artwork.photos.map { |p| { signedId: p.blob.signed_id, url: url_for(p) } } %>
  <div data-react-multi-image-upload
       data-input-name="artwork[photos][]"
       data-existing-photos="<%= existing.to_json.html_safe %>">
  </div>
</div>
